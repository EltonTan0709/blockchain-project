DATABASE_URL=postgres://USERNAME.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres
# Optional: cap Prisma connections when using a pooled Postgres URL locally.
PRISMA_CONNECTION_LIMIT=1
PONDER_DATABASE_SCHEMA=ponder
NEXT_PUBLIC_ADMIN_WALLET=
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_PONDER_URL=http://localhost:42069
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
# Private key for the dedicated oracle worker wallet, not the admin wallet.
ORACLE_AUTOMATION_PRIVATE_KEY=
ORACLE_WORKER_POLL_INTERVAL_MS=15000
# When true, the worker submits real Chainlink Functions requests instead of simulated callback txs.
CHAINLINK_FUNCTIONS_ENABLED=false
