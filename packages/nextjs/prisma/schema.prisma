generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FlightStatus {
  SCHEDULED
  DELAYED
  CANCELLED
  DEPARTED
  ARRIVED
}

enum OracleRequestAuditStatus {
  REQUESTED
  AWAITING_CHAINLINK
  FULFILLED
  FAILED
  EXPIRED
}

model Flight {
  id                 String               @id @default(cuid())
  flightNumber       String
  departureAirport   String
  arrivalAirport     String
  scheduledDeparture DateTime
  scheduledArrival   DateTime
  currentStatus      FlightStatus
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  statusUpdates      FlightStatusUpdate[]

  @@unique([flightNumber, scheduledDeparture])
  @@index([flightNumber])
  @@index([currentStatus])
  @@index([scheduledDeparture])
}

model FlightStatusUpdate {
  id              String       @id @default(cuid())
  flightId        String
  status          FlightStatus
  note            String?
  updatedByWallet String
  createdAt       DateTime     @default(now())
  flight          Flight       @relation(fields: [flightId], references: [id], onDelete: Cascade)

  @@index([flightId, createdAt])
  @@index([status, createdAt])
}

model OracleRequestAudit {
  id                 String                   @id @default(cuid()) @db.Text
  chainId            Int
  policyId           BigInt
  requestId          BigInt?
  chainlinkRequestId String?                  @db.Text
  flightKey          String?                  @db.Text
  requestStatus      Int
  auditStatus        OracleRequestAuditStatus
  usedChainlink      Boolean
  flightId           String?                  @db.Text
  flightNumber       String?                  @db.Text
  flightStatus       FlightStatus?
  latestNote         String?                  @db.Text
  outcome            Int?
  delayMinutes       Int?
  payoutEligible     Boolean?
  payoutExecuted     Boolean?
  payoutAmount       String?                  @db.Text
  transactionHash    String?                  @db.Text
  errorMessage       String?                  @db.Text
  metadata           Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@unique([chainId, policyId])
  @@index([chainId, auditStatus])
  @@index([chainId, chainlinkRequestId])
  @@index([chainId, requestId])
  @@map("OracleRequestAudit")
}
